#!/bin/sh
# Gradle wrapper bootstrap script
# 1. Ensure gradle-wrapper.jar exists (with mirror fallback)
# 2. Pre-download Gradle distribution if not cached (with mirror fallback)
# 3. Invoke GradleWrapperMain

APP_BASE_DIR="$(cd "$(dirname "$0")" && pwd)"
WRAPPER_JAR="$APP_BASE_DIR/gradle/wrapper/gradle-wrapper.jar"
WRAPPER_PROPS="$APP_BASE_DIR/gradle/wrapper/gradle-wrapper.properties"

# Parse version from properties
DIST_URL=$(grep distributionUrl "$WRAPPER_PROPS" | sed 's/.*=//' | sed 's/\\:/:/g')
GRADLE_VERSION=$(echo "$DIST_URL" | sed 's/.*gradle-//' | sed 's/-bin.*//' | sed 's/-all.*//')
DIST_NAME="gradle-${GRADLE_VERSION}-bin.zip"

# Validate that a file is a real JAR/ZIP (starts with PK magic bytes)
is_valid_zip() {
    [ -s "$1" ] || return 1
    MAGIC=$(od -A n -N 2 -t x1 "$1" 2>/dev/null | tr -d ' ')
    [ "$MAGIC" = "504b" ]
}

try_download() {
    local url="$1" dest="$2" label="$3" timeout="${4:-60}"
    rm -f "$dest"
    echo "  Trying $label..."
    curl -fSL --connect-timeout 15 --max-time "$timeout" -o "$dest" "$url" 2>/dev/null || \
    wget -q --timeout=15 -O "$dest" "$url" 2>/dev/null
    [ -s "$dest" ]
}

# ===== Step 1: Ensure gradle-wrapper.jar =====
if [ ! -f "$WRAPPER_JAR" ] || ! is_valid_zip "$WRAPPER_JAR"; then
    rm -f "$WRAPPER_JAR"
    echo "Downloading Gradle wrapper jar..."

    # Custom mirror (env var)
    if [ -n "$GRADLE_WRAPPER_MIRROR" ]; then
        try_download "$GRADLE_WRAPPER_MIRROR" "$WRAPPER_JAR" "custom mirror"
        is_valid_zip "$WRAPPER_JAR" || rm -f "$WRAPPER_JAR"
    fi

    # China mirrors → extract jar from dist zip
    if [ ! -s "$WRAPPER_JAR" ]; then
        for MIRROR_BASE in \
            "https://mirrors.cloud.tencent.com/gradle/" \
            "https://mirrors.aliyun.com/macports/distfiles/gradle/"; do
            DIST_TMP=$(mktemp /tmp/gradle-dist-XXXXXX.zip)
            try_download "${MIRROR_BASE}${DIST_NAME}" "$DIST_TMP" "China mirror ($MIRROR_BASE)" 120
            if is_valid_zip "$DIST_TMP"; then
                unzip -p "$DIST_TMP" "*/gradle/wrapper/gradle-wrapper.jar" > "$WRAPPER_JAR" 2>/dev/null
                if is_valid_zip "$WRAPPER_JAR"; then rm -f "$DIST_TMP"; break; fi
                rm -f "$WRAPPER_JAR"
            fi
            rm -f "$DIST_TMP"
        done
    fi

    # GitHub raw
    if [ ! -s "$WRAPPER_JAR" ]; then
        try_download "https://raw.githubusercontent.com/gradle/gradle/v${GRADLE_VERSION}/gradle/wrapper/gradle-wrapper.jar" \
            "$WRAPPER_JAR" "GitHub" 60
        is_valid_zip "$WRAPPER_JAR" || rm -f "$WRAPPER_JAR"
    fi

    if ! is_valid_zip "$WRAPPER_JAR"; then
        rm -f "$WRAPPER_JAR"
        echo "Error: Failed to download gradle-wrapper.jar"
        echo "Place it manually at: $WRAPPER_JAR"
        exit 1
    fi
    echo "  Gradle wrapper jar ready."
fi

# ===== Step 2: Pre-download Gradle distribution (with mirror fallback) =====
GRADLE_USER_HOME="${GRADLE_USER_HOME:-$HOME/.gradle}"
DIST_CACHE="$GRADLE_USER_HOME/wrapper/dists"

# Check if Gradle is already extracted in cache
CACHED_DIR=$(find "$DIST_CACHE" -maxdepth 3 -name "gradle-$GRADLE_VERSION" -type d 2>/dev/null | head -1)

if [ -z "$CACHED_DIR" ]; then
    LOCAL_ZIP="/tmp/$DIST_NAME"

    # Reuse previously downloaded zip if valid
    if [ -s "$LOCAL_ZIP" ] && ! is_valid_zip "$LOCAL_ZIP"; then
        rm -f "$LOCAL_ZIP"
    fi

    if [ ! -s "$LOCAL_ZIP" ]; then
        echo "Downloading Gradle $GRADLE_VERSION distribution..."
        for URL in \
            "$DIST_URL" \
            "https://mirrors.cloud.tencent.com/gradle/$DIST_NAME" \
            "https://mirrors.aliyun.com/macports/distfiles/gradle/$DIST_NAME"; do
            try_download "$URL" "$LOCAL_ZIP" "$URL" 600
            if is_valid_zip "$LOCAL_ZIP"; then
                echo "  Downloaded Gradle distribution successfully."
                break
            fi
            rm -f "$LOCAL_ZIP"
        done
    fi

    if is_valid_zip "$LOCAL_ZIP"; then
        # Point wrapper to local file so it won't re-download
        FILE_URL=$(echo "$LOCAL_ZIP" | sed 's/:/\\:/g')
        sed -i "s|distributionUrl=.*|distributionUrl=file\\\\:${FILE_URL}|" "$WRAPPER_PROPS"
        echo "  Using local distribution: $LOCAL_ZIP"
    else
        echo "Warning: Could not pre-download Gradle distribution."
        echo "  Wrapper will attempt to download from: $DIST_URL"
        echo "  If this fails, manually download $DIST_NAME and place at: /tmp/$DIST_NAME"
    fi
else
    echo "Gradle $GRADLE_VERSION already cached."
fi

# ===== Step 3: Invoke Gradle =====
if [ -n "$JAVA_HOME" ]; then
    JAVACMD="$JAVA_HOME/bin/java"
else
    JAVACMD="java"
fi

exec "$JAVACMD" \
    $JAVA_OPTS \
    -classpath "$WRAPPER_JAR" \
    org.gradle.wrapper.GradleWrapperMain "$@"
